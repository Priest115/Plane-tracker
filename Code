#!/usr/bin/env python3
"""
UK Plane Tracker
────────────────
Three tracking zones, one poll:

  1. WARWICKSHIRE  — any military aircraft in the local box, regardless of type
  2. UK-WIDE       — interesting military (F-35, C-17, P-8 etc.), once per aircraft per day
  3. GLOBAL RARE   — exotic types (B-2, U-2, RC-135 etc.) tracked worldwide

Plus a personal warbird watchlist (MH434, Sally B, SP-MIL etc.) always monitored UK-wide.

Data source  : https://api.adsb.fi    (free, no account needed)
Notifications: https://ntfy.sh        (free, no account needed)

Usage:
  python plane_tracker.py            # run continuously
  python plane_tracker.py --once     # single poll, then exit  ← used by GitHub Actions
  python plane_tracker.py --test     # send a test notification and exit
"""

import argparse
import json
import os
import sys
import time
from datetime import date, datetime
from pathlib import Path

import requests

# ══════════════════════════════════════════════════════════════════════════════
#  CONFIGURATION
#  Values are read from environment variables first (for GitHub Actions),
#  then fall back to the defaults set here (for local use).
#
#  GitHub Actions: add NTFY_TOPIC as a repository secret.
#  Local use: either set it below or export the env var before running.
# ══════════════════════════════════════════════════════════════════════════════

# Your ntfy.sh topic — make this long and random so others can't stumble on it.
# e.g. "plane-alerts-xk7q2m9r"  Create it at https://ntfy.sh (no signup needed).
NTFY_TOPIC = os.getenv("NTFY_TOPIC", "YOUR_TOPIC_HERE")

# How often to poll when running continuously (seconds).
# GitHub Actions enforces a 5-minute minimum; this value only matters for local use.
POLL_INTERVAL = 120

# ── Geographic zones ───────────────────────────────────────────────────────

# Zone 1: Local — any military aircraft here triggers a notification, any type.
# Slightly generous to account for ADS-B coverage gaps at lower altitudes.
WARWICKSHIRE_BOUNDS = {
    "lat_min": 51.9,
    "lat_max": 52.8,
    "lon_min": -2.1,
    "lon_max": -1.1,
}

# Zone 2: UK-wide — standard/daily military notifications.
UK_BOUNDS = {
    "lat_min": 49.5,
    "lat_max": 61.0,
    "lon_min": -8.5,
    "lon_max":  2.5,
}

# Zone 3: Global — no bounding box, see GLOBALLY_RARE_TYPES below.

# ──────────────────────────────────────────────────────────────────────────────
#  WARBIRD / PERSONAL WATCHLIST
#  Use 'reg' for civil registrations. Use 'hex' for aircraft without civil regs
#  (BBMF etc.) — find hex codes at https://globe.adsbexchange.com
# ──────────────────────────────────────────────────────────────────────────────

WARBIRD_WATCHLIST = [
    {"reg": "G-BEDF", "name": "Sally B",  "desc": "B-17 Flying Fortress — only flying example in Europe"},
    {"reg": "G-ASJV", "name": "MH434",    "desc": "Spitfire LF IXb — OFMC Duxford"},
    {"reg": "G-MRLL", "name": "Marinell", "desc": "P-51D Mustang (44-13521) — Duxford"},
    {"reg": "SP-MIL", "name": "SP-MIL",   "desc": "MiG-17 Lim-5 — only airworthy example in Europe"},

    # BBMF — no civil reg, use hex codes found on adsb.fi
    # {"hex": "43C3D4", "name": "BBMF Lancaster", "desc": "Avro Lancaster PA474"},
    # {"hex": "43C6C9", "name": "BBMF Spitfire",  "desc": "Spitfire MK356"},
    # {"hex": "43C6C8", "name": "BBMF Hurricane", "desc": "Hurricane LF363"},

    # Add more as you spot them:
    # {"reg": "G-SIJJ", "name": "Tall in the Saddle", "desc": "P-51D — Hangar 11"},
]

# ──────────────────────────────────────────────────────────────────────────────
#  MILITARY AIRCRAFT RULES
#
#  GLOBALLY_RARE_TYPES — tracked worldwide, no geo filter, daily dedup.
#  DAILY_NOTIFY_TYPES  — UK-wide, first sighting per aircraft per day.
#  SKIP_TYPES          — too frequent UK-wide; ignored for UK notifications
#                        but still fire locally if over Warwickshire.
# ──────────────────────────────────────────────────────────────────────────────

GLOBALLY_RARE_TYPES = {
    "B2",     # B-2 Spirit
    "U2",     # U-2S Dragon Lady
    "WC135",  # WC-135 Constant Phoenix — nuclear sniffer
    "B52",    # B-52H Stratofortress
    "B1",     # B-1B Lancer
    "RC135",  # RC-135 Rivet Joint / Cobra Ball / Combat Sent
    "E3",     # E-3 Sentry AWACS
    "RQ4",    # RQ-4 Global Hawk / NATO AGS
    "WP3",    # WP-3D Orion — NOAA hurricane hunters
}

DAILY_NOTIFY_TYPES = {
    "F35",    # F-35A/B/C Lightning II
    "F22",    # F-22 Raptor
    "F15",    # F-15 Eagle / Strike Eagle
    "F16",    # F-16 Fighting Falcon
    "A10",    # A-10 Thunderbolt II
    "C17",    # C-17 Globemaster III
    "P8",     # P-8A Poseidon
    "E7",     # E-7A Wedgetail
    "AH64",   # Apache
    "F18",    # F/A-18
}

SKIP_TYPES = {
    "EF",     # Eurofighter Typhoon — ~160 in RAF service
    "C130",   # C-130J Hercules
    "A400",   # A400M Atlas
    "CH47",   # Chinook
    "MRTT",   # Voyager KC2/KC3 tanker
    "H135",   # H135
    "AS365",  # Dauphin
}

MIN_ALT_FT = 500


# ══════════════════════════════════════════════════════════════════════════════
#  INTERNALS
# ══════════════════════════════════════════════════════════════════════════════

ADSB_BASE  = "https://api.adsb.fi/v1"
STATE_FILE = Path(__file__).parent / "tracker_state.json"
HEADERS    = {"User-Agent": "uk-plane-tracker/1.0 (personal project)"}


# ── State ──────────────────────────────────────────────────────────────────

def load_state() -> dict:
    if STATE_FILE.exists():
        try:
            with open(STATE_FILE) as f:
                return json.load(f)
        except (json.JSONDecodeError, OSError):
            pass
    return {"date": "", "airborne": {}, "seen_warks": {}, "seen_uk": {}, "seen_global": {}}


def save_state(state: dict):
    with open(STATE_FILE, "w") as f:
        json.dump(state, f, indent=2)


def maybe_reset_daily(state: dict) -> dict:
    today = str(date.today())
    if state.get("date") != today:
        state.update({"date": today, "seen_warks": {}, "seen_uk": {}, "seen_global": {}})
    for key in ("airborne", "seen_warks", "seen_uk", "seen_global"):
        state.setdefault(key, {})
    return state


# ── API ────────────────────────────────────────────────────────────────────

def adsb_get(path: str) -> list:
    try:
        r = requests.get(f"{ADSB_BASE}/{path}", headers=HEADERS, timeout=15)
        if r.status_code == 404:
            return []
        r.raise_for_status()
        return r.json().get("ac", [])
    except requests.RequestException as e:
        log(f"API error ({path}): {e}")
        return []


def fetch_all_military() -> list:
    return adsb_get("mil")


def fetch_by_reg(reg: str) -> dict | None:
    results = adsb_get(f"reg/{reg.upper()}")
    return results[0] if results else None


def fetch_by_hex(hex_code: str) -> dict | None:
    results = adsb_get(f"icao/{hex_code.lower()}")
    return results[0] if results else None


# ── Helpers ────────────────────────────────────────────────────────────────

def in_bounds(ac: dict, bounds: dict) -> bool:
    lat, lon = ac.get("lat"), ac.get("lon")
    if lat is None or lon is None:
        return False
    return (bounds["lat_min"] <= lat <= bounds["lat_max"] and
            bounds["lon_min"] <= lon <= bounds["lon_max"])


def is_airborne(ac: dict) -> bool:
    alt = ac.get("alt_baro", 0)
    gs  = ac.get("gs", 0) or 0
    if alt == "ground":
        return False
    try:
        return int(alt) >= MIN_ALT_FT
    except (TypeError, ValueError):
        return float(gs) > 30


def get_type(ac: dict) -> str:
    return (ac.get("t") or ac.get("type") or "").upper().replace("-", "").replace(" ", "")


def is_globally_rare(ac: dict) -> bool:
    t = get_type(ac)
    return any(r in t for r in GLOBALLY_RARE_TYPES)


def is_daily_notify(ac: dict) -> bool:
    t = get_type(ac)
    return any(d in t for d in DAILY_NOTIFY_TYPES)


def is_skipped_uk(ac: dict) -> bool:
    t = get_type(ac)
    return any(s in t for s in SKIP_TYPES)


def map_url(ac: dict) -> str | None:
    icao = (ac.get("hex") or "").strip()
    if icao:
        return f"https://globe.adsbexchange.com/?icao={icao.lower()}"
    lat, lon = ac.get("lat"), ac.get("lon")
    if lat is not None and lon is not None:
        return f"https://globe.adsbexchange.com/?lat={lat:.3f}&lon={lon:.3f}&zoom=10"
    return None


def format_message(ac: dict, note: str = "") -> str:
    lines = [note] if note else []
    reg      = (ac.get("r")      or "").strip()
    callsign = (ac.get("flight") or "").strip()
    ac_type  = (ac.get("t")      or ac.get("type") or "").strip()
    alt      = ac.get("alt_baro")
    gs       = ac.get("gs")
    track    = ac.get("track")
    squawk   = ac.get("squawk", "")

    if reg:      lines.append(f"Reg: {reg}")
    if callsign: lines.append(f"Callsign: {callsign}")
    if ac_type:  lines.append(f"Type: {ac_type}")
    if squawk:   lines.append(f"Squawk: {squawk}")

    if alt == "ground":
        lines.append("On ground")
    elif alt is not None:
        try:    lines.append(f"Alt: {int(alt):,} ft")
        except: pass

    if gs is not None:
        try:    lines.append(f"Speed: {int(gs)} kts")
        except: pass

    if track is not None:
        try:    lines.append(f"Heading: {int(track)}°")
        except: pass

    return "\n".join(lines)


def log(msg: str):
    print(f"[{datetime.now().strftime('%H:%M:%S')}] {msg}")


# ── ntfy.sh notifications ──────────────────────────────────────────────────
#
#  Priority: 1=min  2=low  3=default  4=high  5=max (max bypasses iOS Focus)
#  Tags    : ntfy emoji shortcodes, comma-separated — shown as emoji prefix
#  Click   : URL opened when the notification is tapped (the map link)

def ntfy(title: str, message: str, priority: int = 3,
         tags: str = "", url: str | None = None):
    headers: dict = {
        "Title":    title,
        "Priority": str(priority),
    }
    if tags:
        headers["Tags"] = tags
    if url:
        headers["Click"] = url

    try:
        r = requests.post(
            f"https://ntfy.sh/{NTFY_TOPIC}",
            data=message.encode("utf-8"),
            headers=headers,
            timeout=10,
        )
        r.raise_for_status()
        log(f"  → ntfy sent: {title}")
    except requests.RequestException as e:
        log(f"  → ntfy FAILED: {e}")


# ── Core logic ─────────────────────────────────────────────────────────────

def check_warbids(state: dict) -> dict:
    for bird in WARBIRD_WATCHLIST:
        reg  = bird.get("reg")
        hex_ = bird.get("hex")
        name = bird["name"]
        key  = (reg or hex_).upper()

        ac = fetch_by_reg(reg) if reg else fetch_by_hex(hex_)
        time.sleep(0.75)

        if ac is None or not is_airborne(ac):
            if key in state["airborne"]:
                log(f"  {name} landed / off coverage")
                del state["airborne"][key]
            continue

        if key not in state["airborne"]:
            state["airborne"][key] = True
            log(f"  ✈  {name} airborne — notifying")
            ntfy(
                title=f"✈️ {name} is flying!",
                message=format_message(ac, note=bird["desc"]),
                priority=3,
                tags="airplane",
                url=map_url(ac),
            )
        else:
            log(f"  {name} airborne (already notified this flight)")

    return state


def check_military(state: dict) -> dict:
    all_mil     = fetch_all_military()
    airborne    = [a for a in all_mil if is_airborne(a)]
    warbird_keys = {(b.get("reg") or b.get("hex", "")).upper() for b in WARBIRD_WATCHLIST}

    log(f"Military tracked globally: {len(all_mil)}")

    # ── Pass 1: Global rare ────────────────────────────────────────────────
    for ac in airborne:
        if not is_globally_rare(ac):
            continue
        icao    = (ac.get("hex") or "").lower()
        ac_type = (ac.get("t") or ac.get("type") or "Unknown").strip()
        if icao and icao not in state["seen_global"]:
            state["seen_global"][icao] = True
            log(f"  🌍 GLOBAL RARE: {ac_type}")
            ntfy(
                title=f"🌍 {ac_type} tracked globally",
                message=format_message(ac),
                priority=5,
                tags="globe_with_meridians,rotating_light",
                url=map_url(ac),
            )

    # ── Pass 2: Warwickshire — any military type ───────────────────────────
    warks = [a for a in airborne if in_bounds(a, WARWICKSHIRE_BOUNDS)]
    log(f"Military over Warwickshire: {len(warks)}")

    for ac in warks:
        icao    = (ac.get("hex") or "").lower()
        ac_type = (ac.get("t") or ac.get("type") or "Military aircraft").strip()
        if icao and icao not in state["seen_warks"]:
            state["seen_warks"][icao] = True
            log(f"  🎯 WARWICKSHIRE: {ac_type}")
            ntfy(
                title=f"🎯 Military overhead — {ac_type}",
                message=format_message(ac, note="In Warwickshire airspace"),
                priority=4,
                tags="dart",
                url=map_url(ac),
            )

    # ── Pass 3: UK standard ────────────────────────────────────────────────
    uk = [a for a in airborne if in_bounds(a, UK_BOUNDS)]
    log(f"Military in UK: {len(uk)}")

    for ac in uk:
        icao    = (ac.get("hex") or "").lower()
        ac_type = (ac.get("t") or ac.get("type") or "Unknown military").strip()
        if not icao or is_globally_rare(ac) or is_skipped_uk(ac):
            continue
        if is_daily_notify(ac) and icao not in state["seen_uk"]:
            state["seen_uk"][icao] = True
            log(f"  🛡  UK: {ac_type}")
            ntfy(
                title=f"🛡️ Military UK: {ac_type}",
                message=format_message(ac),
                priority=3,
                tags="shield",
                url=map_url(ac),
            )

    # ── Tidy airborne dict ─────────────────────────────────────────────────
    current = {(a.get("hex") or "").lower() for a in all_mil}
    for k in [k for k in list(state["airborne"]) if k not in current and k not in warbird_keys]:
        del state["airborne"][k]

    return state


# ── Entry point ────────────────────────────────────────────────────────────

def run_once():
    log("── Poll ───────────────────────────────────────────────────")
    state = maybe_reset_daily(load_state())
    state = check_warbids(state)
    state = check_military(state)
    save_state(state)
    log("── Done ────────────────────────────────────────────────────")


def main():
    parser = argparse.ArgumentParser()
    parser.add_argument("--once", action="store_true", help="Single poll then exit")
    parser.add_argument("--test", action="store_true", help="Send test notification then exit")
    args = parser.parse_args()

    if NTFY_TOPIC == "YOUR_TOPIC_HERE":
        print("ERROR: Set NTFY_TOPIC in the script or as an environment variable.")
        sys.exit(1)

    if args.test:
        log("Sending test notification...")
        ntfy(
            title="✅ Plane Tracker — test",
            message=(
                "Notifications working.\n\n"
                "Zones active:\n"
                "  🌍 Global rare (B-2, U-2, RC-135...)\n"
                "  🎯 Warwickshire (any military)\n"
                "  🛡️  UK-wide (F-35, C-17, P-8...)\n"
                "  ✈️  Warbird watchlist"
            ),
            priority=3,
            tags="white_check_mark",
        )
        return

    if args.once:
        run_once()
        return

    log("Running continuously. Ctrl+C to stop.")
    while True:
        try:
            run_once()
        except KeyboardInterrupt:
            log("Stopped.")
            break
        except Exception as e:
            log(f"Error: {e}")
        log(f"Sleeping {POLL_INTERVAL}s...")
        time.sleep(POLL_INTERVAL)


if __name__ == "__main__":
    main()
